{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./",
    "rootDir": "./",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "noImplicitAny": true,
    "lib": ["ES2020", "DOM"]
  },
  "include": ["preload.ts", "index.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "tests", "**/*.test.ts"]
}
