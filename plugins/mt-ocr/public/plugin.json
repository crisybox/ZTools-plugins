{
  "$schema": "node_modules/@ztools-center/ztools-api-types/resource/ztools.schema.json",
  "name": "mt-ocr",
  "title": "馒头OCR",
  "description": "支持腾讯云/百度云/阿里云的多引擎 OCR 文字识别工具",
  "author": "menghaohao",
  "version": "1.0.0",
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.svg",
